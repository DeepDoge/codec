{
	"name": "@nomadshiba/codec",
	"version": "0.4.4",
	"license": "LGPL-2.1-only",
	"exports": "./lib/mod.ts",
	"tasks": {
		"check": "deno check && deno lint && deno test",
		"publish:jsr": "git push https://github.com/DeepDoge/codec.git master"
	},
	"compilerOptions": {
		"lib": [
			"deno.window",
			"deno.unstable",
			"esnext"
		]
	},
	"imports": {
		"@std/assert": "jsr:@std/assert@^1.0.19",
		"~/": "./lib/"
	},
	"lint": {
		"rules": {
			"exclude": ["no-explicit-any"],
			"include": ["no-slow-types"]
		}
	},
	"fmt": {
		"useTabs": true,
		"indentWidth": 4,
		"lineWidth": 160
	}
}
